{
  "name": "@seanchatmangpt/wminml",
  "version": "26.4.8",
  "description": "70+ ML algorithms across 15 families with AutoML, SIMD acceleration, and zero dependencies. Rust/WASM, browser + Node.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./worker": {
      "import": "./dist/worker.js",
      "types": "./dist/worker.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp wasm/miniml_core_bg.wasm dist/",
    "build:wasm": "cd ../../crates/miniml-core && wasm-pack build --target web --out-dir ../../packages/miniml/wasm",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist wasm",
    "prepublishOnly": "pnpm build && pnpm test && pnpm typecheck"
  },
  "keywords": [
    "machine-learning",
    "automl",
    "wasm",
    "webassembly",
    "classification",
    "regression",
    "clustering",
    "preprocessing",
    "time-series",
    "knn",
    "random-forest",
    "gradient-boosting",
    "decision-tree",
    "svm",
    "naive-bayes",
    "logistic-regression",
    "kmeans",
    "dbscan",
    "pca",
    "monte-carlo",
    "markov-chain",
    "hmm",
    "mcmc",
    "bayesian",
    "gaussian-process",
    "survival-analysis",
    "kernel-methods",
    "graph-algorithms",
    "recommendation",
    "association-rules",
    "statistical-inference",
    "hypothesis-testing",
    "anomaly-detection",
    "drift-detection",
    "genetic-algorithm",
    "pso",
    "simulated-annealing",
    "simd"
  ],
  "author": "Sean Chatman",
  "license": "BSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/seanchatmangpt/miniml"
  },
  "homepage": "https://github.com/seanchatmangpt/miniml#readme",
  "bugs": {
    "url": "https://github.com/seanchatmangpt/miniml/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/seanchatmangpt"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
